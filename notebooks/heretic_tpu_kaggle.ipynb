    "# Heretic on TPU v5e-8 (Kaggle)\n",
    "\n",
    "This notebook runs Heretic (fully automatic censorship removal for LLMs) on Kaggle TPU v5e-8.\n",
    "\n",
    "**Requirements:**\n",
    "- Kaggle TPU quota (8 cores = v5e-8)\n",
    "- Internet access for model/dataset download\n",
    "- ~30-60 minutes per model depending on size\n",
    "\n",
    "**Supported Models:**\n",
    "- Single TPU core (16GB HBM): 3B-8B models\n",
    "- Multi-core FSDP (128GB HBM): 9B-14B+ models\n",
    "\n",
    "**Models Tested:**\n",
    "- DeepSeek-R1-Distill-Qwen-7B/14B\n",
    "- Qwen3.5-9B\n",
    "- Llama-3.1-8B-Instruct\n",
    "- Gemma-2-9B-IT\n",
    "- Mistral-Nemo-12B-Instruct\n",
    "- Phi-4 / Phi-4-mini\n",
    "- And more..."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 1: Install Dependencies\n",
    "# ============================================================\n",
    "# Run this cell first - installs PyTorch/XLA and Heretic with TPU support\n",
    "\n",
    "%pip install -q torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu\n",
    "%pip install -q \"torch_xla[tpu] @ https://storage.googleapis.com/tpu-pytorch/wheels/tpuvm/torch_xla-2.6.0-cp310-cp310-manylinux_2_17_x86_64.manylinux2014_x86_64.whl\"\n",
    "%pip install -q \"heretic-llm[tpu] @ git+https://github.com/p-e-w/heretic.git\"\n",
    "\n",
    "# Verify installations\n",
    "import torch\n",
    "import torch_xla\n",
    "print(f\"PyTorch: {torch.__version__}\")\n",
    "print(f\"torch_xla: {torch_xla.__version__}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 2: Initialize TPU\n",
    "# ============================================================\n",
    "# This MUST be run before any model loading\n",
    "\n",
    "import os\n",
    "os.environ[\"PJRT_DEVICE\"] = \"TPU\"\n",
    "os.environ[\"XLA_USE_BF16\"] = \"1\"\n",
    "os.environ[\"XLA_DOWNCAST_BF16\"] = \"1\"\n",
    "os.environ[\"TOKENIZERS_PARALLELISM\"] = \"false\"\n",
    "\n",
    "import torch_xla.core.xla_model as xm\n",
    "\n",
    "device = xm.xla_device()\n",
    "num_cores = xm.xla_device_count()\n",
    "print(f\"TPU device: {device}\")\n",
    "print(f\"Number of cores: {num_cores}\")\n",
    "print(f\"HW type: {xm.xla_device_hw(device)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 3: Configure Model\n",
    "# ============================================================\n",
    "# Select your model and parallelism strategy\n",
    "\n",
    "# === MODEL SELECTION ===\n",
    "# Uncomment the model you want to abliterate:\n",
    "\n",
    "MODEL = \"deepseek-ai/DeepSeek-R1-Distill-Qwen-7B\"        # 7B - Single core OK\n",
    "# MODEL = \"deepseek-ai/DeepSeek-R1-Distill-Qwen-14B\"       # 14B - Needs FSDP (8 cores)\n",
    "# MODEL = \"Qwen/Qwen3.5-9B\"                                # 9B - Single core tight, FSDP better\n",
    "# MODEL = \"meta-llama/Meta-Llama-3.1-8B-Instruct\"          # 8B - Single core OK\n",
    "# MODEL = \"deepseek-ai/DeepSeek-R1-Distill-Llama-8B\"       # 8B - Single core OK\n",
    "# MODEL = \"microsoft/phi-4\"                                # 14B - Needs FSDP\n",
    "# MODEL = \"google/gemma-2-9b-it\"                           # 9B - Single core tight\n",
    "# MODEL = \"mistralai/Mistral-Nemo-12B-Instruct\"            # 12B - Needs FSDP\n",
    "# MODEL = \"CohereForAI/c4ai-command-r-8b\"                  # 8B - Single core OK\n",
    "# MODEL = \"meta-llama/Llama-3.2-3B-Instruct\"               # 3B - Single core easy\n",
    "# MODEL = \"internlm/internlm2.5-7b-chat\"                   # 7B - Single core OK\n",
    "# MODEL = \"01-ai/Yi-1.5-9B-Chat-16K\"                       # 9B - Needs FSDP (long context)\n",
    "# MODEL = \"ibm-granite/granite-4.1-8b-instruct\"            # 8B - Single core OK\n",
    "# MODEL = \"microsoft/Phi-4-mini-instruct\"                  # 3.8B - Single core easy\n",
    "# MODEL = \"HuggingFaceTB/SmolLM3-3B\"                       # 3B - Single core easy\n",
    "\n",
    "# === PARALLELISM STRATEGY ===\n",
    "# auto = automatically choose based on model size\n",
    "# single = force single TPU core (16GB HBM)\n",
    "# fsdp = force FSDP across all 8 cores (128GB HBM)\n",
    "PARALLELISM = \"auto\"  # \"auto\" | \"single\" | \"fsdp\"\n",
    "\n",
    "# === OPTIMIZATION SETTINGS ===\n",
    "N_TRIALS = 200          # Number of abliteration trials (reduce for large models)\n",
    "N_STARTUP_TRIALS = 60   # Random exploration trials\n",
    "BATCH_SIZE = 0          # 0 = auto-detect\n",
    "MAX_RESPONSE_LENGTH = 100\n",
    "\n",
    "# === OUTPUT SETTINGS ===\n",
    "SAVE_MODEL = True       # Save merged model locally\n",
    "UPLOAD_TO_HF = False    # Upload to Hugging Face Hub\n",
    "HF_REPO_ID = \"your-username/model-name-heretic\"  # If uploading\n",
    "HF_PRIVATE = True       # Private repo\n",
    "\n",
    "print(f\"Model: {MODEL}\")\n",
    "print(f\"Parallelism: {PARALLELISM}\")\n",
    "print(f\"Trials: {N_TRIALS}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 4: Auto-configure based on model size\n",
    "# ============================================================\n",
    "\n",
    "from heretic.config import Settings\n",
    "from heretic.system import detect_tpu\n",
    "\n",
    "# Rough parameter count estimation from model name\n",
    "def estimate_params(model_id: str) -> int:\n",
    "    import re\n",
    "    model_lower = model_id.lower()\n",
    "    \n",
    "    # Match patterns like 7b, 7B, 14b, 3.5b, etc.\n",
    "    patterns = [\n",
    "        r'(\\d+\\.?\\d*)[bB]',  # 7b, 7B, 3.5b, 14b\n",
    "        r'-(\\d+\\.?\\d*)b',     # -7b, -14b\n",
    "    ]\n",
    "    for pat in patterns:\n",
    "        matches = re.findall(pat, model_lower)\n",
    "        if matches:\n",
    "            # Take the largest match (usually the param count)\n",
    "            vals = [float(m) for m in matches]\n",
    "            return int(max(vals) * 1e9)\n",
    "    return 7_000_000_000  # default\n",
    "\n",
    "param_count = estimate_params(MODEL)\n",
    "print(f\"Estimated parameters: {param_count/1e9:.1f}B\")\n",
    "\n",
    "# Auto-detect parallelism strategy\n",
    "if PARALLELISM == \"auto\":\n",
    "    if param_count <= 8_000_000_000:\n",
    "        PARALLELISM = \"single\"\n",
    "    else:\n",
    "        PARALLELISM = \"fsdp\"\n",
    "    print(f\"Auto-selected: {PARALLELISM}\")\n",
    "\n",
    "# Configure settings\n",
    "tpu_cores = 1 if PARALLELISM == \"single\" else 8\n",
    "use_fsdp = PARALLELISM == \"fsdp\"\n",
    "\n",
    "settings = Settings(\n",
    "    model=MODEL,\n",
    "    dtypes=[\"bfloat16\"],  # TPU requires bfloat16\n",
    "    quantization=\"none\",  # bitsandbytes not supported on TPU\n",
    "    device_map=\"auto\",\n",
    "    offload_outputs_to_cpu=True,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    max_response_length=MAX_RESPONSE_LENGTH,\n",
    "    n_trials=N_TRIALS,\n",
    "    n_startup_trials=N_STARTUP_TRIALS,\n",
    "    tpu_cores=tpu_cores,\n",
    "    tpu_use_fsdp=use_fsdp,\n",
    "    row_normalization=\"full\",\n",
    "    full_normalization_lora_rank=3,\n",
    "    orthogonalize_direction=True,\n",
    "    winsorization_quantile=1.0,\n",
    "    study_checkpoint_dir=\"/kaggle/working/checkpoints\",\n",
    "    system_prompt=\"You are a helpful assistant.\",\n",
    ")\n",
    "\n",
    "print(\"Settings configured successfully\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 5: Run Heretic Abliteration\n",
    "# ============================================================\n",
    "\n",
    "from heretic.main import run\n",
    "from heretic.config import Settings\n",
    "\n",
    "# Override sys.argv to pass our settings\n",
    "import sys\n",
    "sys.argv = [\n",
    "    \"heretic\",\n",
    f"    \"--model={MODEL}\",\n",
    "    \"--dtypes=bfloat16\",\n",
    "    \"--quantization=none\",\n",
    "    \"--device-map=auto\",\n",
    "    \"--offload-outputs-to-cpu\",\n",
    f"    \"--n-trials={N_TRIALS}\",\n",
    f"    \"--n-startup-trials={N_STARTUP_TRIALS}\",\n",
    f"    \"--tpu-cores={tpu_cores}\",\n",
    f"    \"--tpu-use-fsdp={str(use_fsdp).lower()}\",\n",
    "    \"--row-normalization=full\",\n",
    "    \"--full-normalization-lora-rank=3\",\n",
    "    \"--orthogonalize-direction\",\n",
    "    \"--winsorization-quantile=1.0\",\n",
    "    \"--study-checkpoint-dir=/kaggle/working/checkpoints\",\n",
    "]\n",
    "\n",
    "if SAVE_MODEL:\n",
    "    sys.argv.append(\"--save-directory=/kaggle/working/model\")\n",
    "\n",
    "if UPLOAD_TO_HF:\n",
    "    sys.argv.extend([\n",
    "        \"--upload-repo-id\", HF_REPO_ID,\n",
    "        \"--upload-repo-private\", str(HF_PRIVATE).lower(),\n",
    "    ])\n",
    "\n",
    "print(\"Starting Heretic abliteration...\")\n",
    "print(\"This may take 20-60 minutes depending on model size and parallelism.\")\n",
    "\n",
    "run()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
